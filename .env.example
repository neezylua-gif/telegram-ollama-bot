# Telegram
TELEGRAM_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_telegram_id_here
ADMIN_HISTORY_INTERVAL=0

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
TEXT_MODEL=qwen2.5-coder:7b
VISION_MODEL=qwen3-vl:4b
OLLAMA_TIMEOUT=600
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096
TEXT_TEMPERATURE=0.15
VISION_TEMPERATURE=0.1

# Потоковая генерация сообщений
STREAMING_ENABLED=true
STREAM_EDIT_INTERVAL=0.9
STREAM_MIN_CHARS=20

# Полный программный код
CODE_NUM_CTX=12288
CODE_NUM_PREDICT=5000

# Длинные тексты: рефераты, статьи, доклады
LONG_TEXT_NUM_CTX=16384
LONG_TEXT_NUM_PREDICT=7500
LONG_TEXT_TIMEOUT=600

# История и файлы
MAX_HISTORY_MESSAGES=20
MAX_HISTORY_CHARS=24000
MAX_DOCUMENT_CHARS=50000
MAX_FILE_BYTES=20000000
MAX_IMAGE_PIXELS=40000000
IMAGE_MAX_SIDE=1600
TELEGRAM_CHUNK_SIZE=3900
HTTP_TRUST_ENV=false

# Чтение сайтов
WEB_FETCH_ENABLED=true
WEB_REQUEST_TIMEOUT=25
WEB_MAX_RESPONSE_BYTES=5000000
WEB_MAX_PAGE_CHARS=18000
WEB_MAX_TOTAL_CHARS=28000
WEB_MAX_URLS=3
WEB_MAX_REDIRECTS=5
WEB_MAX_LINKS=30
WEB_ALLOWED_PORTS=80,443
WEB_USER_AGENT=Mozilla/5.0 (compatible; LocalOllamaTelegramBot/1.0)

# Создание статического проекта сайта
WEBSITE_RECREATION_ENABLED=true
WEBSITE_BROWSER_TIMEOUT=45
WEBSITE_BROWSER_CHANNEL=
WEBSITE_BROWSER_EXECUTABLE=

# Генерация проекта
WEBSITE_NUM_CTX=12288
WEBSITE_NUM_PREDICT=3200
WEBSITE_GENERATION_TIMEOUT=300

# Vision отключён для быстрого и стабильного парсинга скелета.
# Поставь true, если нужен дополнительный анализ скриншотов.
WEBSITE_VISION_ENABLED=false
WEBSITE_VISION_TIMEOUT=55
WEBSITE_VISION_NUM_PREDICT=450

# Если Ollama зависнет или вернёт ошибку, ZIP всё равно будет собран из DOM и CSS.
WEBSITE_FAST_FALLBACK=true

# Ограничения данных сайта и готового проекта
WEBSITE_MAX_HTML_CHARS=30000
WEBSITE_MAX_CSS_CHARS=18000
WEBSITE_MAX_TEXT_CHARS=14000
WEBSITE_MAX_FILES=8
WEBSITE_MAX_PROJECT_CHARS=350000